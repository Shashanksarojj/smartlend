# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── SendGrid ──────────────────────────────────────────────────
# Get your API key from https://app.sendgrid.com/settings/api_keys
# Verify your sender address at https://app.sendgrid.com/settings/sender_auth
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=SmartLend

# ── Notification channel toggles ──────────────────────────────
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false
NOTIFICATION_WHATSAPP_ENABLED=false

# ── WhatsApp Cloud API ─────────────────────────────────────────
# Setup guide: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# 1. Create a Meta App at developers.facebook.com
# 2. Add WhatsApp product → get test Phone Number ID and temporary access token
# 3. Create 3 message templates in Meta Business Manager (names must match below):
#    - loan_approved  → body params: {{1}} name  {{2}} amount  {{3}} emi  {{4}} tenure months
#    - loan_rejected  → body params: {{1}} name  {{2}} loanId
#    - emi_due        → body params: {{1}} name  {{2}} amount  {{3}} dueDate
# 4. Set NOTIFICATION_WHATSAPP_ENABLED=true once templates are approved
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_API_VERSION=v19.0
WHATSAPP_LANGUAGE_CODE=en
WHATSAPP_WEBHOOK_VERIFY_TOKEN=smartlend-webhook-secret
WHATSAPP_TEMPLATE_LOAN_APPROVED=loan_approved
WHATSAPP_TEMPLATE_LOAN_REJECTED=loan_rejected
WHATSAPP_TEMPLATE_EMI_DUE=emi_due

# ── Frontend (optional — defaults work for local dev) ─────────
# REACT_APP_USER_URL=http://localhost:8081/api
# REACT_APP_LOAN_URL=http://localhost:8082/api
# REACT_APP_AI_URL=http://localhost:8000
