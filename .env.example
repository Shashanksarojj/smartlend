# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── SendGrid ──────────────────────────────────────────────────
# Get your API key from https://app.sendgrid.com/settings/api_keys
# Verify your sender address at https://app.sendgrid.com/settings/sender_auth
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=SmartLend

# ── Notification channel toggles ──────────────────────────────
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false

# ── Frontend (optional — defaults work for local dev) ─────────
# REACT_APP_USER_URL=http://localhost:8081/api
# REACT_APP_LOAN_URL=http://localhost:8082/api
# REACT_APP_AI_URL=http://localhost:8000
